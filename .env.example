## Server 
NODE_ENV=development
HOST=localhost
PORT=3000

## CORS 
CORS_ORIGIN=http://localhost:4028
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE

## JWT
JWT_ACCESS_SECRET=your_access_secret_key
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_TTL=7d

## LOG 
LOG_LEVEL=debug
LOG_DIR=logs
LOG_FILE_NAME=log_xxx.log
LOG_MAX_SIZE=5 # MB

## REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=1 ## redis-cli -n 1

## MONGODB
MONGO_URI=mongodb://localhost:27018/restaurant_manager?replicaSet=rs0&directConnection=true

## MAIL SERVICE 
SMTP_SERVICE=gmail
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password

## GOOGLE OAUTH2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auths/google/callback

## CLIENT 
CLIENT_URL=http://localhost:4028/

## QUICK QR
BANK_ID=bank_id 
ACCOUNT_NO=account_no
TEMPLATE=compact
